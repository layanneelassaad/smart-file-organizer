{
    "manifest_version": 3, 
    "name": "Smart File Organizer", 
    "version": "1.0", 
    "description": "Capture file downloads and display their metadata.",
    "permissions": [
      "downloads", 
      "storage"
    ],
    "background": {
      "service_worker": "background.js" 
    },
    "action": {
      "default_popup": "popup.html", 
      "default_title": "Smart File Organizer" 
    },
    "host_permissions": [
      "http://*/*",
      "https://*/*"
    ]
  }
  